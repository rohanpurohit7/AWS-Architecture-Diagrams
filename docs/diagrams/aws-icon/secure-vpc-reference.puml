@startuml SecureVPCReference
!define AWSPuml https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v23.0/dist
!include AWSPuml/AWSCommon.puml
!include AWSPuml/NetworkingContentDelivery/all.puml
!include AWSPuml/SecurityIdentityCompliance/all.puml
!include AWSPuml/Compute/all.puml
!include AWSPuml/Containers/all.puml
!include AWSPuml/Database/all.puml
!include AWSPuml/ManagementGovernance/all.puml
!include AWSPuml/Storage/all.puml

skinparam backgroundColor #FFFFFF
skinparam packageStyle rectangle
skinparam shadowing false
left to right direction

title Secure Multi-AZ AWS Application Architecture

Route53(route53, "Route 53", "DNS")
CloudFront(cloudfront, "CloudFront", "Edge cache")
WebApplicationFirewall(waf, "AWS WAF", "Layer 7 protection")

package "AWS Account" {
  package "AWS Region" {
    package "VPC 10.20.0.0/16" {
      InternetGateway(igw, "Internet Gateway", "Public ingress")
      ElasticLoadBalancing(alb, "Application Load Balancer", "Public subnets")
      NATGateway(natA, "NAT Gateway A", "AZ-a egress")
      NATGateway(natB, "NAT Gateway B", "AZ-b egress")

      package "Availability Zone A" {
        package "Public subnet 10.20.0.0/24" {
          alb
          natA
        }
        package "Private application subnet 10.20.10.0/24" {
          ElasticKubernetesService(eksA, "EKS workloads", "Pod replicas")
        }
        package "Isolated data subnet 10.20.20.0/24" {
          RelationalDatabaseService(rdsA, "Aurora/RDS", "Writer/reader")
        }
      }

      package "Availability Zone B" {
        package "Public subnet 10.20.1.0/24" {
          natB
        }
        package "Private application subnet 10.20.11.0/24" {
          ElasticKubernetesService(eksB, "EKS workloads", "Pod replicas")
        }
        package "Isolated data subnet 10.20.21.0/24" {
          RelationalDatabaseService(rdsB, "Aurora/RDS", "Standby/reader")
        }
      }

      NetworkFirewall(firewall, "AWS Network Firewall", "Inspection and egress policy")
      VirtualPrivateCloud(vpc, "Amazon VPC", "Routing and segmentation")
    }

    CloudWatch(cloudwatch, "CloudWatch", "Metrics and alarms")
    CloudTrail(cloudtrail, "CloudTrail", "API audit")
    SimpleStorageService(logs, "Amazon S3", "Central log archive")
  }
}

route53 --> cloudfront
cloudfront --> waf
waf --> igw
igw --> alb
alb --> eksA
alb --> eksB
eksA --> rdsA
eksB --> rdsB
eksA --> firewall : controlled egress
eksB --> firewall : controlled egress
firewall --> natA
firewall --> natB
eksA --> cloudwatch
eksB --> cloudwatch
cloudtrail --> logs
cloudwatch --> logs

legend right
  |= Boundary |= Meaning |
  | AWS Account | governance and billing boundary |
  | Region | service location and data-residency boundary |
  | VPC | network trust boundary |
  | AZ | failure-domain boundary |
  | Subnet | routing and workload-placement boundary |
endlegend
@enduml
