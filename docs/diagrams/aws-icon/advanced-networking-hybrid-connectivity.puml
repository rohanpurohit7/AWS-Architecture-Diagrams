@startuml
!define AWSPuml https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v23.0/dist
!include AWSPuml/AWSCommon.puml
!include AWSPuml/NetworkingContentDelivery/all.puml
!include AWSPuml/SecurityIdentityCompliance/all.puml
!include AWSPuml/ManagementGovernance/all.puml

DirectConnect(dx, "Direct Connect", "primary hybrid path")
SitetoSiteVPN(vpn, "Site-to-Site VPN", "resilient backup")
TransitGateway(tgw, "Transit Gateway", "hub routing")
VirtualPrivateCloud(inspect, "Inspection VPC", "centralized security")
NetworkFirewall(nfw, "Network Firewall", "traffic inspection")
VPCNATGateway(nat, "NAT Gateway", "controlled egress")
VirtualPrivateCloud(prod, "Production VPC", "private workloads")
VirtualPrivateCloud(shared, "Shared Services VPC", "DNS and platform services")
CloudWatch(cw, "CloudWatch", "network telemetry")

dx --> tgw
vpn --> tgw
tgw --> inspect
inspect --> nfw
nfw --> nat
tgw --> prod
tgw --> shared
nfw --> cw
@enduml