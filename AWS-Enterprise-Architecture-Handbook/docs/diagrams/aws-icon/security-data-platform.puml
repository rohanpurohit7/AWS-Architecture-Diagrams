left to right direction
CloudTrail(trail,"CloudTrail","API activity")
GuardDuty(gd,"GuardDuty","threat findings")
EventBridge(events,"EventBridge","finding routing")
Lambda(enrich,"Lambda","enrichment and triage")
SecurityLake(lake,"Security Lake","central security data")
OpenSearchService(search,"OpenSearch","search and SIEM")
SecurityHub(hub,"Security Hub","finding aggregation")
Detective(det,"Detective","investigation")
SimpleStorageService(archive,"S3","long-term evidence archive")
SimpleNotificationService(alerts,"SNS","human alerts")
trail --> lake
gd --> hub
hub --> events
events --> enrich
enrich --> alerts
lake --> search
lake --> archive
hub --> det
