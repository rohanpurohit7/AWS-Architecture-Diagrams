@startuml
!define AWSPuml https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v23.0/dist
!include AWSPuml/AWSCommon.puml
!include AWSPuml/ApplicationIntegration/all.puml
!include AWSPuml/Compute/all.puml
!include AWSPuml/Database/all.puml
!include AWSPuml/Storage/all.puml
!include AWSPuml/ManagementGovernance/all.puml
!include AWSPuml/NetworkingContentDelivery/all.puml

APIGateway(api, "Agent API", "governed entry")
Lambda(fn, "Bedrock Supervisor Adapter", "agent orchestration")
EventBridge(bus, "Security Event Bus", "event intake")
SimpleQueueService(q, "Agent Work Queue", "buffer and retry")
StepFunctions(sf, "Approval Workflow", "bounded orchestration")
DynamoDB(db, "Case State", "agent and approval state")
SimpleStorageService(s3, "Approved Runbooks", "knowledge source")
CloudWatch(cw, "Agent Telemetry", "logs and alarms")

api --> fn
fn --> bus
bus --> q
q --> sf
sf --> db
sf --> s3
fn --> cw
sf --> cw
@enduml
