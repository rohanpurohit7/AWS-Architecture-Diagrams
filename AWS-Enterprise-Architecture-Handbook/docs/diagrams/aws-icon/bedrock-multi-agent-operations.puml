@startuml
!define AWSPuml https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v23.0/dist
!include AWSPuml/AWSCommon.puml
!include AWSPuml/ArtificialIntelligence/Bedrock.puml
!include AWSPuml/ApplicationIntegration/EventBridge.puml
!include AWSPuml/ApplicationIntegration/StepFunctions.puml
!include AWSPuml/Compute/Lambda.puml
!include AWSPuml/Database/DynamoDB.puml
!include AWSPuml/Storage/SimpleStorageService.puml
!include AWSPuml/ManagementGovernance/CloudWatch.puml
left to right direction
EventBridge(ev,"Security and Ops Events","event intake")
StepFunctions(sf,"Step Functions","workflow orchestration")
Bedrock(model,"Amazon Bedrock","reasoning and summarization")
Lambda(triage,"Triage Agent","read-only enrichment")
Lambda(remediation,"Remediation Advisor","recommendations")
Lambda(tool,"Bounded Tool Adapter","allowlisted actions")
SimpleStorageService(s3,"Approved Runbooks","governed knowledge")
DynamoDB(state,"Case State","workflow context")
CloudWatch(cw,"CloudWatch","audit and telemetry")
ev --> sf
sf --> triage
sf --> remediation
triage --> model
remediation --> model
triage --> s3
remediation --> tool
tool --> state
sf --> cw
@enduml
