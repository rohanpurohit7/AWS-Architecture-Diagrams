@startuml
!define AWSPuml https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v23.0/dist
!include AWSPuml/AWSCommon.puml
!include AWSPuml/ApplicationIntegration/all.puml
!include AWSPuml/Compute/all.puml
!include AWSPuml/Database/all.puml
!include AWSPuml/Storage/all.puml
!include AWSPuml/ManagementGovernance/all.puml
!include AWSPuml/NetworkingContentDelivery/all.puml

APIGateway(api, "Global Application Entry", "multi-region ingress")
Lambda(fn, "Regional Application", "active application processing")
EventBridge(bus, "Replication Events", "cross-region event routing")
SimpleQueueService(q, "Replication Queue", "buffer and retry")
StepFunctions(sf, "Failover Workflow", "regional failover orchestration")
DynamoDB(db, "Global State", "replicated application state")
SimpleStorageService(s3, "Replicated Objects", "cross-region object storage")
CloudWatch(cw, "Regional Health", "health and alarms")

api --> fn
fn --> bus
bus --> q
q --> sf
sf --> db
sf --> s3
fn --> cw
sf --> cw
@enduml
